# Sitio protegido (Tigo Portal u otro) — no commitear .env real
SECURE_SITE_BASE_URL=https://portal.ejemplo.tigo/
# Opción A: ticket ya emitido (sesión/API)
SECURE_SITE_BEARER=
SECURE_SITE_COOKIE=
# Opción B: login por PIN (nombres de campos según el formulario HTML real)
SECURE_SITE_LOGIN_URL=https://portal.ejemplo.tigo/login
SECURE_SITE_PIN_FIELD=pin
SECURE_SITE_PIN=
# Cookies de sesión esperadas tras login (opcional, separadas por coma)
SECURE_SITE_SESSION_COOKIES=SESSIONID,auth_token
