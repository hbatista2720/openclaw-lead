# Entorno LOCAL (solo Mac / Docker Desktop). Copiar antes del primer uso:
#   cp infra/env.development.example infra/env.development
# infra/env.development está en .gitignore (no sube a Git).
#
# Levantar solo Twenty local:
#   ./scripts/dev-local-up.sh

SERVER_URL=http://localhost:30002
TWENTY_HTTP_PORT=30002

TAG=latest
STORAGE_TYPE=local

PG_DATABASE_USER=postgres
PG_DATABASE_PASSWORD=postgres_local_dev
PG_DATABASE_NAME=default
PG_DATABASE_HOST=db
PG_DATABASE_PORT=5432

REDIS_URL=redis://redis:6379

APP_SECRET=local_dev_replace_with_random_string_use_openssl

# Correo local: dejar LOGGER para no configurar SMTP mientras pruebas
EMAIL_DRIVER=LOGGER
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=Twenty Local
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_NO_TLS=false
IS_EMAIL_VERIFICATION_REQUIRED=false

# OpenClaw (opcional): no necesario para probar Twenty
# OPENCLAW_GATEWAY_PORT=30003
