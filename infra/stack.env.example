# Copiar a la raíz del proyecto como `.env` antes de levantar el stack:
#   cp infra/stack.env.example .env
# y editar secretos. Sin `.env`, Twenty no recibe SERVER_URL y el stack falla.
#
# Arranque:
#   docker compose up -d
#     → solo Twenty (CRM) + Postgres + Redis
#   docker compose --profile openclaw up -d --build
#     → además OpenClaw (compila la imagen; puede tardar y exigir RAM)

# --- Twenty CRM (imagen oficial; ver también packages/twenty-docker en el repo clonado) ---
TAG=latest
# Debe coincidir con TWENTY_HTTP_PORT (URL que usa el navegador / callbacks)
TWENTY_HTTP_PORT=30002
SERVER_URL=http://localhost:30002
STORAGE_TYPE=local
PG_DATABASE_PASSWORD=cambiar_password_postgres_seguro
APP_SECRET=cambiar_con_openssl_rand_base64_32
# En VPS usar la URL pública, p. ej. https://crm.tudominio.com
# SERVER_URL=https://crm.tudominio.com

# --- OpenClaw Gateway (imagen oficial; evita build local que puede OOM) ---
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
# Variante más pequeña: ghcr.io/openclaw/openclaw:slim
OPENCLAW_GATEWAY_TOKEN=cambiar_con_openssl_rand_hex_32
# Host 30003/30004 → contenedor 18789/18790 (OpenClaw)
OPENCLAW_GATEWAY_PORT=30003
OPENCLAW_BRIDGE_PORT=30004
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_TZ=America/Panama
# Rutas en el host (se crean al levantar; ver docker-compose volumenes)
OPENCLAW_CONFIG_DIR=./data/openclaw-config
OPENCLAW_WORKSPACE_DIR=./data/openclaw-workspace
# Misma red Docker: Twenty API/UI interna en http://server:3000 (alias de twenty-server)
# TWENTY_INTERNAL_URL=http://server:3000

# --- Correo Twenty (notificaciones, invitaciones, reset password) ---
# Documentación upstream: https://docs.twenty.com/start/self-hosting/#email
# Las variables deben estar en `.env` en la raíz; `docker-compose.yml` las inyecta en server y worker.
#
# Gmail / Google Workspace (recomendado: contraseña de aplicación, no la contraseña de la cuenta):
#   https://support.google.com/accounts/answer/185833
# Opción A — STARTTLS (puerto 587, suele funcionar bien detrás de VPN/firewall):
#   EMAIL_DRIVER=SMTP
#   EMAIL_SMTP_HOST=smtp.gmail.com
#   EMAIL_SMTP_PORT=587
#   EMAIL_SMTP_USER=tu_cuenta@gmail.com
#   EMAIL_SMTP_PASSWORD=xxxx xxxx xxxx xxxx   # contraseña de aplicación (16 caracteres)
#   EMAIL_SMTP_NO_TLS=false
# Opción B — SMTPS (puerto 465):
#   EMAIL_SMTP_PORT=465
# EMAIL_FROM_ADDRESS debe coincidir con la cuenta que autentica (o un alias autorizado en Workspace).
EMAIL_DRIVER=LOGGER
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=Twenty CRM
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_NO_TLS=false
IS_EMAIL_VERIFICATION_REQUIRED=false
